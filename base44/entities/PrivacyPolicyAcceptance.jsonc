{
  "name": "PrivacyPolicyAcceptance",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string",
      "description": "ID of the user who accepted the policy"
    },
    "policy_version": {
      "type": "number",
      "description": "Version number of the PrivacyPolicyConfig that was accepted"
    },
    "accepted_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp of acceptance"
    }
  },
  "required": [
    "user_id",
    "policy_version",
    "accepted_at"
  ],
  "rls": {
    "create": {
      "created_by_id": "{{user.id}}"
    },
    "read": {
      "$or": [
        {
          "data.user_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}